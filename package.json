{
  "name": "monaco-review",
  "version": "0.3.0",
  "description": "Code review extension for the Monaco editor - inline comments, replies, edit history",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jburrow/monaco-editor-code-review.git"
  },
  "homepage": "https://github.com/jburrow/monaco-editor-code-review#readme",
  "bugs": {
    "url": "https://github.com/jburrow/monaco-editor-code-review/issues"
  },
  "keywords": [
    "monaco",
    "monaco-editor",
    "code-review",
    "comments",
    "annotations"
  ],
  "prettier": {
    "printWidth": 120
  },
  "scripts": {
    "start": "vite",
    "build": "tsup",
    "build:demo": "vite build",
    "typecheck": "tsc --noEmit",
    "doc": "typedoc --out ./docs ./src/index.ts",
    "screenshot": "node scripts/update-screenshot.mjs",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run build",
    "prepare": "husky"
  },
  "author": "James Burrow",
  "license": "MIT",
  "peerDependencies": {
    "monaco-editor": ">=0.34.0"
  },
  "dependencies": {
    "dompurify": "^3.4.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "dayjs": "1.11.21",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.0",
    "marked": "^18.0.5",
    "monaco-editor": "0.55.1",
    "prettier": "^3.4.2",
    "puppeteer-core": "^25.1.0",
    "tsup": "^8.5.1",
    "typedoc": "0.28.19",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": "prettier --write"
  }
}
