{
  "name": "monaco-review",
  "version": "0.1.0",
  "description": "Code review extension for the Monaco editor - inline comments, replies, edit history",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/docs*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jburrow/monaco-editor-code-review.git"
  },
  "homepage": "https://github.com/jburrow/monaco-editor-code-review#readme",
  "bugs": {
    "url": "https://github.com/jburrow/monaco-editor-code-review/issues"
  },
  "keywords": [
    "monaco",
    "monaco-editor",
    "code-review",
    "comments",
    "annotations"
  ],
  "prettier": {
    "printWidth": 120
  },
  "scripts": {
    "start": "webpack serve",
    "compile": "tsc && webpack --mode=production",
    "tsc": "tsc --watch",
    "doc": "typedoc --out ./docs ./src/index.ts",
    "lint": "eslint src",
    "test": "jest --coverage",
    "prepublishOnly": "npm run compile",
    "prepare": "husky"
  },
  "author": "James Burrow",
  "license": "MIT",
  "peerDependencies": {
    "monaco-editor": ">=0.34.0"
  },
  "dependencies": {
    "dompurify": "^3.4.9",
    "showdown": "^2.1.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/runtime": "7.29.2",
    "@babel/types": "7.29.0",
    "@eslint/js": "^9.17.0",
    "@types/jest": "29.5.14",
    "@types/showdown": "^2.0.6",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@webpack-cli/serve": "3.0.0",
    "babel-jest": "30.3.0",
    "dayjs": "1.11.20",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "^16.0.0",
    "monaco-editor": "0.55.1",
    "prettier": "^3.4.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "typedoc": "0.28.19",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": "prettier --write"
  }
}
